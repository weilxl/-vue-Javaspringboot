{"ast":null,"code":"//\n//\n//\n//\n//\n//\n//\n//\n\nexport default {\n  name: 'TextTabBar',\n  props: {\n    active: {\n      type: String,\n      \"default\": 'todo'\n    }\n  },\n  methods: {\n    go: function go(path) {\n      this.$router.push(path);\n    }\n  }\n};","map":{"version":3,"names":["name","props","active","type","String","methods","go","path","$router","push"],"sources":["src/components/TextTabBar.vue"],"sourcesContent":["<template>\r\n  <div class=\"tab-bar\">\r\n    <div class=\"tab-item\" :class=\"{ active: active === 'todo' }\" @click=\"go('/todo-task')\">待办任务</div>\r\n    <div class=\"tab-item\" :class=\"{ active: active === 'schedule' }\" @click=\"go('/schedule')\">日程安排</div>\r\n    <div class=\"tab-item\" :class=\"{ active: active === 'mine' }\" @click=\"go('/mine')\">我的</div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'TextTabBar',\r\n  props: {\r\n    active: {\r\n      type: String,\r\n      default: 'todo'\r\n    }\r\n  },\r\n  methods: {\r\n    go(path) {\r\n      this.$router.push(path)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.tab-bar {\r\n  position: fixed;\r\n  bottom: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  display: flex;\r\n  background: #fff;\r\n  border-top: 1px solid #e5e7eb;\r\n  z-index: 1000;\r\n}\r\n\r\n.tab-item {\r\n  flex: 1;\r\n  text-align: center;\r\n  padding: 18px 0;\r\n  color: #64748b;\r\n  cursor: pointer;\r\n  font-size: 14px;\r\n}\r\n\r\n.tab-item.active {\r\n  color: #4198ac;\r\n  font-weight: 700;\r\n}\r\n</style>\r\n"],"mappings":";;;;;;;;;AASA;EACAA,IAAA;EACAC,KAAA;IACAC,MAAA;MACAC,IAAA,EAAAC,MAAA;MACA;IACA;EACA;EACAC,OAAA;IACAC,EAAA,WAAAA,GAAAC,IAAA;MACA,KAAAC,OAAA,CAAAC,IAAA,CAAAF,IAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}